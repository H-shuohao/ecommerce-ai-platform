# API authentication. Keep disabled for local demos; enable it in deployed environments.
API_AUTH_ENABLED=false
API_VIEWER_KEY=
API_SERVICE_KEY=
API_ADMIN_KEY=
LOG_LEVEL=INFO

# Volcano account credentials. Keep real values only in .env.
VOLC_ACCESS_KEY=
VOLC_SECRET_KEY=

# Ark model call used by our custom RAG callback.
ARK_API_KEY=
ARK_ENDPOINT_ID=

# RTC room info returned to the frontend.
RTC_APP_ID=
RTC_APP_KEY=
RTC_ROOM_ID=ChatRoom01
RTC_USER_ID=Huoshan01
RTC_TOKEN=

# Voice chat task and agent identity.
VOICE_CHAT_TASK_ID=ChatTask01
AGENT_USER_ID=ChatBot01
AGENT_WELCOME_MESSAGE=你好，我是小懒，有什么需要帮忙的吗？

# ASR/TTS app ids.
ASR_APP_ID=
TTS_APP_ID=

# Public URL that Volcano RTC can call back, for example an ngrok URL.
SERVER_URL=

# Volcano Knowledge Base config.
VOLC_ACCOUNT_ID=
KB_PROJECT_NAME=default
KB_COLLECTION_NAME=dw_ai

# Low-score chunks are omitted from the LLM prompt, but the LLM still answers normally.
KB_MIN_RELEVANCE_SCORE=0.22
KB_MAX_CONTEXT_CHARS=500
